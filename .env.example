# ─────────────────────────────────────────────
# AgentPeXI — Variabili d'ambiente
# Copiare in .env e compilare tutti i valori.
# Non committare mai .env nel repository.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agentpexi:changeme@localhost:5432/agentpexi
# (sync, usata da Alembic per le migrazioni)
DATABASE_SYNC_URL=postgresql://agentpexi:changeme@localhost:5432/agentpexi

# ── Redis / Celery ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO (object storage) ────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agentpexi
MINIO_SECURE=false

# ── Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Maps ───────────────────────────────
# Abilitare: Places API (New), Geocoding API
GOOGLE_MAPS_API_KEY=AIza...

# ── Gmail API (OAuth2) ───────────────────────
# Creare credenziali OAuth2 su Google Cloud Console.
# Scope richiesto: https://www.googleapis.com/auth/gmail.send
#                  https://www.googleapis.com/auth/gmail.readonly
# Per istruzioni dettagliate sul setup (refresh token, rinnovo): docs/security.md
GMAIL_CLIENT_ID=...apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...
# Indirizzo mittente (deve corrispondere all'account OAuth)
GMAIL_SENDER_ADDRESS=noreply@example.com

# ── Autenticazione ────────────────────────────
# Chiave per JWT dashboard operatore. Min 32 caratteri, random.
SECRET_KEY=changeme_at_least_32_chars_random
# Chiave separata per JWT portale cliente. Diversa da SECRET_KEY.
PORTAL_SECRET_KEY=changeme_portal_at_least_32_chars_random

# ── Operatore ─────────────────────────────────
OPERATOR_NAME=Mario Rossi
OPERATOR_EMAIL=mario@example.com
OPERATOR_PHONE=+39 000 0000000

# ── Applicazione ──────────────────────────────
# URL base pubblico (usato per i link portale nelle email)
BASE_URL=http://localhost:3000
# Porta FastAPI
API_PORT=8000
# Ambiente: "development" | "production"
ENVIRONMENT=development

# ── Fatture in Cloud (API fatturazione elettronica) ──
# Ottenere token da: https://fattureincloud.it → Impostazioni → API
FATTURE_IN_CLOUD_ACCESS_TOKEN=...
FATTURE_IN_CLOUD_COMPANY_ID=...

# ── Registro Imprese / CCIAA ──────────────────
# API pubblica per ricerca P.IVA e dati aziendali italiani.
# Documentazione: config/external_apis.yaml
REGISTRO_IMPRESE_API_KEY=

# ── Workspace cliente (locale) ────────────────
# Directory radice per i workspace clienti (solo sviluppo)
CLIENT_WORKSPACE_ROOT=/workspace/clients

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
# "json" in produzione, "console" in sviluppo
LOG_FORMAT=console
